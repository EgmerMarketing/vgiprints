{% comment %}
  VGI Prints — Client Storefront Hero Section
  Displays above the collection product grid on locked collection pages.
  Each client gets their own logo, hero image, welcome message, and deadline.
{% endcomment %}

<div class="school-hero">
  {% if section.settings.hero_image != blank %}
    <div class="school-hero__bg">
      <img
        src="{{ section.settings.hero_image | image_url: width: 1600 }}"
        alt="{{ section.settings.org_name }}"
        width="1600"
        height="500"
        loading="eager"
      >
      <div class="school-hero__overlay"></div>
    </div>
  {% endif %}

  <div class="school-hero__inner page-width">
    {% if section.settings.org_logo != blank %}
      <div class="school-hero__logo">
        <img
          src="{{ section.settings.org_logo | image_url: width: 240 }}"
          alt="{{ section.settings.org_name }} logo"
          width="240"
          height="auto"
          loading="eager"
        >
      </div>
    {% endif %}

    <div class="school-hero__text">
      {% if section.settings.org_name != blank %}
        <h1 class="school-hero__title h1">{{ section.settings.org_name }}</h1>
      {% endif %}

      {% if section.settings.order_deadline != blank %}
        <p class="school-hero__deadline">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 4v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Order by: <strong>{{ section.settings.order_deadline }}</strong>
        </p>
      {% endif %}

      {% if section.settings.welcome_message != blank %}
        <p class="school-hero__message">{{ section.settings.welcome_message }}</p>
      {% endif %}
    </div>

    {% if section.settings.show_contact %}
      <div class="school-hero__contact">
        <p>Questions? <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a> or call <a href="tel:9099572995">(909) 957-2995</a></p>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .school-hero {
    position: relative;
    padding: 56px 0 48px;
    background-color: #1A1A1A;
    overflow: hidden;
  }

  .school-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .school-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .school-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26, 26, 26, 0.88) 0%, rgba(45, 90, 45, 0.7) 100%);
  }

  .school-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .school-hero__logo img {
    max-height: 90px;
    width: auto;
    object-fit: contain;
    border-radius: 4px;
  }

  .school-hero__title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #FFFFFF;
    letter-spacing: -0.01em;
  }

  .school-hero__deadline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(211, 84, 0, 0.15);
    border: 1px solid rgba(211, 84, 0, 0.4);
    border-radius: 4px;
    padding: 8px 16px;
    font-size: 0.88rem;
    font-family: 'Lato', sans-serif;
    color: #D35400;
    margin: 0;
  }

  .school-hero__deadline strong {
    color: #FFFFFF;
  }

  .school-hero__deadline svg {
    flex-shrink: 0;
    color: #D35400;
  }

  .school-hero__message {
    font-size: 1rem;
    font-family: 'Lato', sans-serif;
    color: rgba(255, 255, 255, 0.75);
    max-width: 600px;
    margin: 0;
    line-height: 1.7;
  }

  .school-hero__contact {
    font-size: 0.85rem;
    font-family: 'Lato', sans-serif;
    color: rgba(255, 255, 255, 0.55);
  }

  .school-hero__contact a {
    color: #D35400;
    text-decoration: underline;
    text-decoration-color: rgba(211, 84, 0, 0.4);
    text-underline-offset: 3px;
  }

  .school-hero__contact a:hover {
    text-decoration-color: #D35400;
  }

  @media (min-width: 750px) {
    .school-hero {
      padding: 64px 0 56px;
    }

    .school-hero__inner {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 28px;
    }

    .school-hero__text {
      flex: 1;
    }
  }
</style>

{% schema %}
{
  "name": "Client Storefront Hero",
  "tag": "section",
  "class": "section-school-hero",
  "settings": [
    {
      "type": "text",
      "id": "org_name",
      "label": "Client / Organization Name",
      "default": "Lincoln Elementary"
    },
    {
      "type": "image_picker",
      "id": "org_logo",
      "label": "Client Logo",
      "info": "Swap this per client — their school or company logo"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image",
      "info": "Swap this per client — shows behind the text with a dark overlay"
    },
    {
      "type": "text",
      "id": "order_deadline",
      "label": "Order Deadline",
      "placeholder": "April 30, 2026",
      "info": "Leave blank to hide the deadline badge"
    },
    {
      "type": "textarea",
      "id": "welcome_message",
      "label": "Welcome Message",
      "default": "Welcome to your official spirit wear store. All orders ship directly to you."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact Email",
      "default": "hello@vgiprints.com"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Show contact info",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Client Storefront Hero"
    }
  ]
}
{% endschema %}
