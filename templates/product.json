{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "inventory": {
          "type": "inventory",
          "settings": {
            "text_style": "body",
            "inventory_threshold": 10,
            "show_inventory_quantity": true
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "trust_badges": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'trust-badges' %}"
          }
        },
        "description": {
          "type": "description"
        },
        "tab_printing": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Print Method & Quality",
            "icon": "fire",
            "content": "<p>All products are produced using professional-grade equipment. Depending on the item, we use <strong>DTF (Direct Transfer Film)</strong>, <strong>screen printing</strong>, or <strong>embroidery</strong> for the best possible result.</p><p>Our prints are vibrant, wash-resistant, and built to last through daily wear.</p>",
            "page": ""
          }
        },
        "tab_sizing": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Sizing & Fit",
            "icon": "ruler",
            "content": "<p>Sizing varies by brand and garment type. If you're unsure, we recommend ordering one size up for a relaxed fit. Contact us for a detailed size chart for your specific item.</p>",
            "page": ""
          }
        },
        "tab_turnaround": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Turnaround & Shipping",
            "icon": "truck",
            "content": "<p>Standard turnaround is <strong>5-7 business days</strong> from order confirmation. Rush orders may be available — contact us to discuss.</p><p>School and organization orders are typically delivered directly to the school or pickup location.</p>",
            "page": ""
          }
        },
        "tab_care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care Instructions",
            "icon": "heart",
            "content": "<p>To keep your custom apparel looking its best:</p><ul><li>Wash inside out in cold water</li><li>Tumble dry on low heat or hang dry</li><li>Do not iron directly over the print</li><li>Do not bleach</li></ul>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "inventory",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "trust_badges",
        "description",
        "tab_printing",
        "tab_sizing",
        "tab_turnaround",
        "tab_care",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "media_position": "left",
        "constrain_to_viewport": true,
        "image_zoom": "hover",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 48,
        "padding_bottom": 24
      }
    },
    "trust_bar": {
      "type": "multicolumn",
      "blocks": {
        "col_quality": {
          "type": "column",
          "settings": {
            "title": "Premium Quality",
            "text": "<p>Professional-grade DTF, screen printing, and embroidery on every order.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "col_turnaround": {
          "type": "column",
          "settings": {
            "title": "Fast Turnaround",
            "text": "<p>Most orders ready in 5-7 business days. Rush options available.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "col_custom": {
          "type": "column",
          "settings": {
            "title": "Fully Custom",
            "text": "<p>Your logo, your colors, your design — exactly how you want it.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": [
        "col_quality",
        "col_turnaround",
        "col_custom"
      ],
      "settings": {
        "title": "",
        "heading_size": "h2",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "center",
        "background_style": "primary",
        "button_label": "",
        "button_link": "",
        "swipe_on_mobile": true,
        "color_scheme": "scheme-2",
        "columns_mobile": "1",
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 52,
        "padding_bottom": 52
      }
    }
  },
  "order": [
    "main",
    "trust_bar",
    "related-products"
  ]
}
